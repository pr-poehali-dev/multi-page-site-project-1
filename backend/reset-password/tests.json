{
  "tests": [
    {
      "name": "OPTIONS returns 200",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Request reset without email returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "request", "email": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Укажите email"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Request reset with unknown email returns 200",
      "method": "POST",
      "path": "/",
      "body": {"action": "request", "email": "nonexistent@example.com"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Confirm with wrong code returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "confirm", "email": "test@example.com", "code": "000000", "new_password": "newpass123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неверный код подтверждения"},
      "bodyMatcher": "partial"
    }
  ]
}
